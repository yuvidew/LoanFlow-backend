// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VIEWER
}

enum EmploymentType {
  SALARIED
  SELF_EMPLOYED
  CONTRACT
}

enum SalaryType {
  BANK_TRANSFER
  CASH
  CHEQUE
}

enum ApplicantStatus {
  ACTIVE
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model LoanApplicant {
  id               String            @id @default(cuid())

  fullName         String
  dateOfBirth      DateTime

  creditScore      Int

  employmentType   EmploymentType

  salaryType       SalaryType

  monthlySalary    Decimal           @db.Decimal(10, 2)

  status           ApplicantStatus

  eligibleProducts EligibleProduct[]

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Product {
  id                         String              @id @default(cuid())

  name                       String
  description                String?

  minAge                     Int
  maxAge                     Int

  minCreditScore             Int

  allowedEmploymentTypes     Json

  allowedSalaryTypes         Json

  minSalary                  Decimal             @db.Decimal(10, 2)

  eligibleProducts           EligibleProduct[]

  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
}

model EligibleProduct {
  id          String         @id @default(cuid())

  applicantId String
  productId   String

  applicant   LoanApplicant  @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  product     Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([applicantId, productId])
}